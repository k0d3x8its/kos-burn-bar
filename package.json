{
  "name": "kos-burn-bar",
  "version": "1.1.0",
  "private": true,
  "scripts": {
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage"
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch": ["**/tests/**/*.test.js"],
    "moduleNameMapper": {
      "^obsidian$": "<rootDir>/tests/__mocks__/obsidian.js"
    },
    "coverageDirectory": "coverage",
    "collectCoverageFrom": ["main.js"]
  },
  "devDependencies": {
    "jest": "^29.7.0"
  }
}
